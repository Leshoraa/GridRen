{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "src/index.ts": {
      "runtime": "vercel-bun@1.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/src/index.ts"
    },
    {
      "source": "/swagger/:path*",
      "destination": "/src/index.ts"
    },
    {
      "source": "/swagger",
      "destination": "/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}