{
  "version": 2,
  "bunVersion": "1.x",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/src/index.ts"
    },
    {
      "source": "/swagger/:path*",
      "destination": "/src/index.ts"
    },
    {
      "source": "/swagger",
      "destination": "/src/index.ts"
    }
  ]
}
